# LinkDropV2 Ignore Patterns

# Temporary and Design Storage (Private Workspaces)
99. temporary_storage/
design_inbox/
admin-static/

# Local Documentation (Private)
docs/
0. docs/
0. rules/
.obsidian/
Ob/
링크드랍/

# Environment and Secrets
.env
.env.local
.venv/
node_modules/
venv/
env/
ENV/
python_venv/
pycache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Google Cloud / OAuth / Firebase Credentials
**/*token.json
**/*credentials.json
**/*service_account.json
**/*service-account.json
**/keyfile.json
**/secret.json
**/secrets.json

# Next.js / React
.next/
out/
build/
dist/
.vercel
.turbo

# OS and IDE files
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Local AI tool settings
.claude/settings.local.json

# Build artifacts
*.tsbuildinfo

# Local test scratch
opal_test/
tmp/

# Data and Artifacts
packages/data/
**/pipeline_state.json

# 대용량 바이너리 (GitHub 50MB 제한 / Vercel 300MB 초과 방지)
apps/web/public/download/*.exe
apps/web/public/download/*.dmg
apps/web/public/download/*.msi
apps/web/public/assets/sfx/

# System / Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
