{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx --yes block-no-verify@1.1.2",
            "timeout": 30
          }
        ],
        "description": "--no-verify 플래그 차단 (CLAUDE.md 규칙 강제)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-quality.js",
            "timeout": 30
          }
        ],
        "description": "git commit 전 secrets/console.log/커밋 메시지 검사"
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/suggest-compact.js",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "도구 호출 횟수 카운팅 — 임계값 도달 시 /compact 제안"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/enforce-crlf.sh"
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6",
  "smallModel": "claude-haiku-4-5-20251001",
  "modelAliases": {
    "haiku": {
      "role": "수집/검색/카운팅/간단한 파일 탐색 및 테스트 실행",
      "model": "claude-haiku-4-5-20251001"
    },
    "sonnet": {
      "role": "분석/비교/요약/코드 리뷰/수정 등 하이 퀄리티 구현",
      "model": "claude-sonnet-4-6"
    },
    "opus": {
      "role": "아키텍처/설계/전략/창의적 판단단 및 큰 구조 의사결정",
      "model": "claude-opus-4-6"
    }
  }
}
