{
  "_spec": "SVG Animation Character Standard v2.0",
  "_thumbnail": {
    "w": 1080, "h": 1920, "ratio": "9:16",
    "format": "PNG-24", "bg": "transparent",
    "note": "대표이미지. 캐릭터 선택 화면 표시용"
  },
  "_layer_canvas": {
    "w": 1920, "h": 1080, "ratio": "16:9",
    "format": "PNG-24", "bg": "transparent",
    "note": "영상 합성용 레이어. body/mouth 모두 이 크기"
  },
  "_layers": {
    "mouth": ["mouth_closed.png", "mouth_half.png", "mouth_open.png"],
    "body":  ["body_front.png", "body_tilt_left.png", "body_tilt_right.png", "body_forward.png"]
  },
  "_timing_default": {
    "body_hz": 0.6,
    "mouth_hz": 0.25,
    "zoom_duration": 0.8
  },
  "_source_grids": {
    "note": "외부 AI가 생성하는 소스 그리드 이미지 (슬라이싱 원본). 2-Grid 체계.",
    "mouth_Grid": {
      "ratio": "16:9",
      "layout": "3열 × 1행",
      "panels": ["mouth_closed", "mouth_half", "mouth_open"],
      "naming": "c{N}_mouth_Grid.png"
    },
    "body_Grid": {
      "ratio": "16:9",
      "layout": "4열 × 1행",
      "panels": ["body_front", "body_tilt_left", "body_tilt_right", "body_forward"],
      "naming": "c{N}_body_Grid.png"
    }
  },

