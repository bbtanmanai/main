# ══════════════════════════════════════════════════════════════════
#  LinkDrop V2 — 환경변수 템플릿
#  이 파일을 복사해서 .env 로 저장하고 값을 채워주세요.
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# ── YouTube ────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_API_KEY_2=
YOUTUBE_EXTRACT_NOTEBOOK_ID=

# ── OpenAI ─────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google OAuth (소셜 로그인용) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google API Key (Gemini) ─────────────────────────────────────────
# ⚠️  .env에 입력하지 마세요.
# 각 팀원이 웹 서비스 우측 상단 설정(⚙) 버튼에서 본인 키를 직접 입력합니다.
# 입력한 키는 브라우저 localStorage / IndexedDB에만 저장됩니다.
# GOOGLE_API_KEY=

# ── Supertone TTS ──────────────────────────────────────────────────
SUPERTONE_API_KEY=

# ── Replicate ──────────────────────────────────────────────────────
REPLICATE_API_TOKEN=

# ── Cloudflare R2 (배경 이미지 라이브러리) ─────────────────────────
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=flux-bg-library
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
CLOUDFLARE_API_TOKEN=

# ── Cloudflare R2 (공용 자산 — 효과음·폰트) ───────────────────────
R2_ASSETS_BUCKET=linkdrop-assets
R2_ASSETS_PUBLIC_URL=

# ── Quiver AI ──────────────────────────────────────────────────────
QUIVER_API_KEY=

# ── NotebookLM ─────────────────────────────────────────────────────
NOTEBOOKLM_BL=
