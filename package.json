{
  "name": "linkdrop-workspace",
  "version": "1.0.0",
  "description": "40대 이상 타겟 AI 크리에이터 양성 콘텐츠 서비스 linkdrop 메인 워크스페이스",
  "private": true,
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:shorts": "npm run dev --workspace=agents/video-processor",
    "dev:scripter": "npm start --workspace=agents/shorts-scripter",
    "dev:user": "npm run dev --workspace=agents/user-manager",
    "mcp:notebooklm": "npm start --workspace=mcp-servers/notebooklm-mcp",
    "mcp:notebooklm-audio": "npm start --workspace=mcp-servers/notebooklm-audio-mcp",
    "mcp:supabase": "npx -y @supabase/mcp-server-supabase",
    "mcp:youtube": "npm start --workspace=mcp-servers/youtube-mcp",
    "install:all": "npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbtanmanai/main.git"
  },
  "bugs": {
    "url": "https://github.com/bbtanmanai/main/issues"
  },
  "homepage": "https://github.com/bbtanmanai/main#readme",
  "workspaces": [
    "apps/*",
    "agents/*",
    "mcp-servers/*"
  ],
  "keywords": [
    "linkdrop",
    "ai-shorts",
    "senior-friendly"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "googleapis": "^126.0.0",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
